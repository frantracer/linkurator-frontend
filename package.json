{
  "name": "linkurator",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "coverage": "jest --coverage",
    "build:capacitor": "CAPACITOR_BUILD=true NEXT_PUBLIC_CAPACITOR_BUILD=true next build",
