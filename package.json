    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@tanstack/react-query": "5.90.12",
    "@types/uuid": "9.0.6",
    "@vercel/analytics": "1.4.1",
    "axios": "1.6.5",
    "daisyui": "4.12.10",
    "next": "15.5.7",
    "next-intl": "3.26.3",
    "react": "19.2.1",
